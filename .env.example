# API Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Authentication (JWT Settings)
JWT_SECRET_KEY=dev_jwt_secret_key_change_me_in_production
JWT_ALGORITHM=HS256

# Database Connection URLs (Local Docker Mappings)
DATABASE_URL=postgresql://medical_ai_user:medical_ai_password@localhost:5432/medical_ai_db
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://medical_ai_mq_user:medical_ai_mq_password@localhost:5672/

# Backend Microservices Mock Ports
SERVICE_SCHEDULING_URL=http://localhost:8001
SERVICE_TELEHEALTH_URL=http://localhost:8002
SERVICE_SCRIBE_URL=http://localhost:8003
SERVICE_AGENT_URL=http://localhost:8004

# LiveKit Server Configuration
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# SMTP Email Notifier Configuration (Fill with actual credentials to receive real emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@telehealth-medical-ai.com
